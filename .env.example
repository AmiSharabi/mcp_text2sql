MCP_HOST=0.0.0.0
MCP_PORT=8000

DB_HOST=localhost
DB_PORT=1433
DB_NAME=YourDb
DB_USER=readonly_user
DB_PASSWORD=replace_me
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERTIFICATE=yes

SQL_TIMEOUT_SECONDS=10
SQL_MAX_ROWS=200
SQL_MAX_TABLES=3
SCHEMA_CACHE_SECONDS=300

LOG_PATH=logs/events.jsonl
DOWNLOADS_DIR=logs/downloads
MCP_PUBLIC_BASE_URL=

# Logging sink options: file | sql | both
LOG_SINK=file
LOG_SQL_FALLBACK_PATH=logs/events_sql_fallback.jsonl

# Optional dedicated SQL Server config for logs sink.
# If omitted, logger will fall back to DB_* values above.
LOG_DB_HOST=
LOG_DB_PORT=
LOG_DB_NAME=
LOG_DB_USER=
LOG_DB_PASSWORD=
LOG_DB_DRIVER=
LOG_DB_ENCRYPT=yes
LOG_DB_TRUST_SERVER_CERTIFICATE=yes
LOG_DB_SCHEMA=mcp_logging
LOG_DB_TABLE=events

OPENAI_API_KEY=replace_me
MCP_API_KEY=replace_with_strong_random_token
